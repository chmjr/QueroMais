# Credenciais da Groq API (Pegue em console.groq.com)
GROQ_API_KEY=gsk_sua_api_key_aqui

# Configurações Evolution API
EVOLUTION_API_URL=http://localhost:8080 # O endereço onde a sua Evolution API roda
EVOLUTION_INSTANCE=sua_instancia # Exemplo: queromais1
EVOLUTION_API_KEY=sua_global_api_key_ou_instance_key

PORT=3000
